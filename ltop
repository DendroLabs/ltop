def etime_seconds(s: str) -> int:
    """Parse ps etime: 'MM:SS', 'HH:MM:SS', or 'DD-HH:MM:SS' to seconds."""
    days = 0
    if "-" in s:
        d, s = s.split("-", 1)
        try:
            days = int(d)
        except ValueError:
            pass
    try:
        parts = [int(x) for x in s.split(":")]
    except ValueError:
        return 0
    while len(parts) < 3:
        parts.insert(0, 0)
    h, m, sec = parts
    return days * 86400 + h * 3600 + m * 60 + sec


SORT_MODES = {
    "cpu":  ("CPU",  lambda p: -p["cpu"]),
    "mem":  ("MEM",  lambda p: -p["rss_mb"]),
    "time": ("TIME", lambda p: -etime_seconds(p["elapsed"])),
    "tok":  ("TOK",  lambda p: -(p.get("tokens") or 0)),
}


def _format_elapsed(secs: int) -> str:
    """Format seconds into ps-style elapsed: MM:SS / HH:MM:SS / DD-HH:MM:SS."""
    if secs < 0:
        secs = 0
    days, secs = divmod(secs, 86400)
    hours, secs = divmod(secs, 3600)
    minutes, seconds = divmod(secs, 60)
    if days > 0:
        return f"{days:d}-{hours:02d}:{minutes:02d}:{seconds:02d}"
    if hours > 0:
        return f"{hours:02d}:{minutes:02d}:{seconds:02d}"
    return f"{minutes:02d}:{seconds:02d}"


def _match_label(command: str) -> str | None:
    for pattern, name in LLM_PATTERNS:
        if re.search(pattern, command, re.IGNORECASE):
            return name
    return None


# Cache of psutil.Process objects across refresh ticks so cpu_percent()
# can compute a proper delta (first call after creation returns 0.0).
_PSUTIL_PROC_CACHE: dict = {}


def _get_llm_processes_psutil() -> list[dict]:
    procs: list[dict] = []
    alive_pids: set[int] = set()
    self_pid = os.getpid()

    attrs = ["pid", "ppid", "name", "cmdline", "create_time",
             "memory_percent", "memory_info"]

    for proc in psutil.process_iter(attrs=attrs):
        try:
            info = proc.info
            pid = info["pid"]
            alive_pids.add(pid)
            if pid == self_pid:
                continue

            cmdline = info.get("cmdline") or []
            command = " ".join(cmdline) if cmdline else (info.get("name") or "")
            if not command:
                continue
            if "ltop" in command:
                continue

            label = _match_label(command)
            if label is None:
                continue

            # CPU% via cached Process so we get a real delta on subsequent ticks.
            cached = _PSUTIL_PROC_CACHE.get(pid)
            if cached is None:
                _PSUTIL_PROC_CACHE[pid] = proc
                try:
                    proc.cpu_percent(None)  # prime baseline
                except (psutil.NoSuchProcess, psutil.AccessDenied):
                    pass
                cpu = 0.0
            else:
                try:
                    cpu = cached.cpu_percent(None)
                except (psutil.NoSuchProcess, psutil.AccessDenied):
                    cpu = 0.0

            mem = float(info.get("memory_percent") or 0.0)
            mi = info.get("memory_info")
            rss_mb = (mi.rss / (1024 * 1024)) if mi else 0.0
            ct = info.get("create_time") or 0
            elapsed = _format_elapsed(int(time.time() - ct)) if ct else "00:00"
            ppid = info.get("ppid") or 0

            procs.append({
                "pid": pid,
                "ppid": ppid,
                "cpu": cpu,
                "mem": mem,
                "rss_mb": rss_mb,
                "elapsed": elapsed,
                "command": command,
                "label": label,
            })
        except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
            continue

    for pid in list(_PSUTIL_PROC_CACHE.keys()):
        if pid not in alive_pids:
            _PSUTIL_PROC_CACHE.pop(pid, None)

    return procs


def _get_llm_processes_ps() -> list[dict]:
    """Fallback using BSD/GNU ps. Works on macOS and Linux only."""
    try:
        result = subprocess.run(
            ["ps", "-eo", "pid,ppid,%cpu,%mem,rss,etime,command"],
            capture_output=True, text=True
        )
    except Exception:
        return []

    procs = []
    seen_pids = set()

    for line in result.stdout.strip().split("\n")[1:]:  # skip header
        line = line.strip()
        if not line:
            continue

        parts = line.split(None, 6)
        if len(parts) < 7:
            continue

        pid_str, ppid_str, cpu_str, mem_str, rss_str, etime_str, command = parts

        try:
            pid = int(pid_str)
        except ValueError:
            continue

        # Match against LLM patterns
        label = None
        for pattern, name in LLM_PATTERNS:
            if re.search(pattern, command, re.IGNORECASE):
                label = name
                break

        if label is None:
            continue

        # Skip grep of ourselves
        if pid == os.getpid():
            continue
        if "ltop" in command:
            continue

        if pid in seen_pids:
            continue
        seen_pids.add(pid)

        try:
            cpu = float(cpu_str)
            mem = float(mem_str)
            rss_kb = int(rss_str)
            ppid = int(ppid_str)
        except ValueError:
            cpu, mem, rss_kb, ppid = 0.0, 0.0, 0, 0

        procs.append({
            "pid": pid,
            "ppid": ppid,
            "cpu": cpu,
            "mem": mem,
            "rss_mb": rss_kb / 1024,
            "elapsed": etime_str.strip(),
            "command": command,
            "label": label,
        })

    return procs


def get_llm_processes() -> list[dict]:
    """Scan running processes and identify LLM-related ones.

    Uses psutil when available (required for Windows, more robust on
    Linux/macOS) and falls back to ps(1) otherwise.
    """
    if HAVE_PSUTIL:
        return _get_llm_processes_psutil()
    return _get_llm_processes_ps()


def load_claude_sessions() -> dict[int, dict]:
    """Load Claude Code session data keyed by PID."""
    if not SESSIONS_DIR.is_dir():
        return {}

    sessions = {}
    for f in SESSIONS_DIR.iterdir():
        if f.suffix != ".json":
            continue
        try:
            data = json.loads(f.read_text())
            pid = data.get("pid")
            if pid:
                sid = data.get("sessionId", "")
                data["tasks"] = load_tasks(sid)
                main_todos, subagents = load_agents(sid)
                data["main_todos"] = main_todos
                data["subagents"] = subagents
                sessions[pid] = data
        except (json.JSONDecodeError, OSError):
            continue
    return sessions


def load_tasks(session_id: str) -> list[dict]:
    """Load tasks for a session."""
    task_dir = TASKS_DIR / session_id
    if not task_dir.is_dir():
        return []

    tasks = []
    for f in task_dir.iterdir():
        if f.suffix != ".json":
            continue
        try:
            tasks.append(json.loads(f.read_text()))
        except (json.JSONDecodeError, OSError):
            continue

    def sort_key(t):
        try:
            return int(t.get("id", 0))
        except (ValueError, TypeError):
            return 0
    tasks.sort(key=sort_key)
    return tasks


def load_agents(session_id: str) -> tuple[list[dict], list[dict]]:
    """Load main agent todos and subagent info from the todos directory.

    Returns (main_todos, subagents) where each subagent is a dict with
    'agent_id' and 'todos' keys.
    """
    if not TODOS_DIR.is_dir() or not session_id:
        return [], []

    main_todos = []
    subagents = []
    prefix = f"{session_id}-agent-"

    for f in TODOS_DIR.iterdir():
        if f.suffix != ".json" or not f.stem.startswith(prefix):
            continue
        agent_id = f.stem[len(prefix):]
        try:
            data = json.loads(f.read_text())
            if not isinstance(data, list):
                continue
        except (json.JSONDecodeError, OSError):
            continue

        if agent_id == session_id:
            main_todos = data
        else:
            if data:  # only include subagents that have todos
                subagents.append({
                    "agent_id": agent_id,
                    "todos": data,
                })

    return main_todos, subagents


def agent_todo_summary(todos: list[dict]) -> str:
    """One-line summary of a todo list."""
    if not todos:
        return ""
    total = len(todos)
    done = sum(1 for t in todos if t.get("status") == "completed")
    active = [t for t in todos if t.get("status") == "in_progress"]
    label = ""
    if active:
        t = active[0]
        label = t.get("activeForm") or t.get("content", "")
        if len(label) > 35:
            label = label[:32] + "..."
    return f"{done}/{total} {label}"


def agent_progress_mini(todos: list[dict], width: int = 10) -> str:
    """Tiny progress bar for a todo list."""
    if not todos:
        return ""
    total = len(todos)
    done = sum(1 for t in todos if t.get("status") == "completed")
    active = sum(1 for t in todos if t.get("status") == "in_progress")
    filled = round(done / total * width)
    partial = round(active / total * width)
    empty = width - filled - partial
    return "#" * filled + ":" * partial + "-" * empty


def get_gpu_utilization() -> int | None:
    """Sudoless macOS GPU utilization via ioreg. Returns 0-100 or None."""
    try:
        result = subprocess.run(
            ["ioreg", "-r", "-d", "1", "-w", "0", "-c", "IOAccelerator"],
            capture_output=True, text=True, timeout=2
        )
    except Exception:
        return None
    m = re.search(r'"Device Utilization %"=(\d+)', result.stdout)
    return int(m.group(1)) if m else None


_SESSION_INFO_CACHE: dict[str, tuple[float, str | None, int | None]] = {}


def get_session_info(cwd: str, session_id: str) -> tuple[str | None, float | None, int | None]:
    """Return (model, last_activity_mtime, context_tokens) for a Claude session.

    context_tokens is the size of the most recent assistant turn's input context
    (input + cache_creation + cache_read), matching what /context reports.
    """
    if not cwd or not session_id:
        return None, None, None
    encoded = cwd.replace("/", "-")
    path = Path.home() / ".claude" / "projects" / encoded / f"{session_id}.jsonl"
    try:
        mtime = path.stat().st_mtime
    except OSError:
        return None, None, None
    key = str(path)
    cached = _SESSION_INFO_CACHE.get(key)
    if cached and cached[0] == mtime:
        return cached[1], mtime, cached[2]
    model = None
    ctx_tokens = None
    try:
        with open(path, "rb") as f:
            f.seek(0, 2)
            size = f.tell()
            f.seek(max(0, size - 65536))
            tail = f.read().decode("utf-8", errors="ignore")
        for line in reversed(tail.splitlines()):
            try:
                d = json.loads(line)
            except json.JSONDecodeError:
                continue
            msg = d.get("message")
            if not isinstance(msg, dict):
                continue
            usage = msg.get("usage")
            if ctx_tokens is None and isinstance(usage, dict):
                ctx_tokens = (
                    int(usage.get("input_tokens") or 0)
                    + int(usage.get("cache_creation_input_tokens") or 0)
                    + int(usage.get("cache_read_input_tokens") or 0)
                )
            if model is None and msg.get("model"):
                model = msg["model"]
            if model is not None and ctx_tokens is not None:
                break
    except OSError:
        pass
    _SESSION_INFO_CACHE[key] = (mtime, model, ctx_tokens)
    return model, mtime, ctx_tokens


_OPENCODE_INFO_CACHE: dict[str, tuple[float, str | None, float | None, int | None]] = {}


def _opencode_db_mtime() -> float | None:
    """Max mtime across the opencode SQLite files (the WAL lags the main db)."""
    latest: float | None = None
    for suffix in ("", "-wal", "-shm"):
        try:
            m = (OPENCODE_DB.parent / f"{OPENCODE_DB.name}{suffix}").stat().st_mtime
        except OSError:
            continue
        if latest is None or m > latest:
            latest = m
    return latest


def get_process_cwd(pid: int) -> str | None:
    """Resolve a process's cwd. psutil on any OS, /proc on Linux as fallback."""
    if HAVE_PSUTIL:
        try:
            return psutil.Process(pid).cwd()
        except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
            return None
    try:
        return os.readlink(f"/proc/{pid}/cwd")
    except OSError:
        return None


def get_opencode_info(cwd: str | None) -> tuple[str | None, float | None, int | None]:
    """Return (model, last_activity_epoch, context_tokens) for an opencode session.

    Looks up the most recent assistant message tied to the session whose
    `directory` column matches the process cwd. If cwd is None (can't resolve)
    or no match exists, falls back to the globally most-recent assistant
    message — good enough when a single opencode instance is active.

    Tokens are input + cache.read + cache.write to match the Claude Code
    "context size" semantic (what `/context` reports) rather than total
    including output.
    """
    db_mtime = _opencode_db_mtime()
    if db_mtime is None:
        return None, None, None

    key = cwd or "__latest__"
    cached = _OPENCODE_INFO_CACHE.get(key)
    if cached and cached[0] == db_mtime:
        return cached[1], cached[2], cached[3]

    model: str | None = None
    last_activity: float | None = None
    ctx_tokens: int | None = None
    try:
        conn = sqlite3.connect(f"file:{OPENCODE_DB}?mode=ro", uri=True, timeout=0.5)
        try:
            if cwd:
                row = conn.execute(
                    "SELECT m.data, m.time_created FROM message m "
                    "JOIN session s ON s.id = m.session_id "
                    "WHERE s.directory = ? "
                    "  AND m.data LIKE '%\"role\":\"assistant\"%' "
                    "ORDER BY m.time_created DESC LIMIT 1",
                    (cwd,),
                ).fetchone()
            else:
                row = None
            if row is None:
                row = conn.execute(
                    "SELECT data, time_created FROM message "
                    "WHERE data LIKE '%\"role\":\"assistant\"%' "
                    "ORDER BY time_created DESC LIMIT 1"
                ).fetchone()
        finally:
            conn.close()
        if row:
            data_str, tc_ms = row
            try:
                d = json.loads(data_str)
            except json.JSONDecodeError:
                d = None
            if isinstance(d, dict):
                model = d.get("modelID")
                last_activity = (tc_ms or 0) / 1000.0
                tok = d.get("tokens") or {}
                if isinstance(tok, dict):
                    cache = tok.get("cache") or {}
                    ctx_tokens = (
                        int(tok.get("input") or 0)
                        + int(cache.get("read") or 0)
                        + int(cache.get("write") or 0)
                    )
    except sqlite3.Error:
        pass

    _OPENCODE_INFO_CACHE[key] = (db_mtime, model, last_activity, ctx_tokens)
    return model, last_activity, ctx_tokens


_RUNNING_AGENTS_CACHE: dict[str, tuple[float, list[dict]]] = {}


def _parse_iso_ts(ts: str | None) -> float | None:
    """Parse an ISO 8601 timestamp (with trailing Z) to a unix float."""
    if not ts:
        return None
    try:
        if ts.endswith("Z"):
            ts = ts[:-1] + "+00:00"
        return datetime.fromisoformat(ts).timestamp()
    except (ValueError, AttributeError):
        return None


def get_running_subagents(cwd: str, session_id: str) -> list[dict]:
    """Return subagents whose tool_use has no matching tool_result yet.

    Each dict: {id, description, subagent_type, started_at}. Scans the tail
    of the transcript (~2MB) which comfortably covers many recent turns.
    """
    if not cwd or not session_id:
        return []
    encoded = cwd.replace("/", "-")
    path = Path.home() / ".claude" / "projects" / encoded / f"{session_id}.jsonl"
    try:
        mtime = path.stat().st_mtime
    except OSError:
        return []
    key = str(path)
    cached = _RUNNING_AGENTS_CACHE.get(key)
    if cached and cached[0] == mtime:
        return cached[1]

    uses: dict[str, dict] = {}
    results: set[str] = set()
    try:
        with open(path, "rb") as f:
            f.seek(0, 2)
            size = f.tell()
            f.seek(max(0, size - 2 * 1024 * 1024))
            if f.tell() > 0:
                f.readline()  # drop the partial first line
            data = f.read().decode("utf-8", errors="ignore")
        for line in data.splitlines():
            try:
                d = json.loads(line)
            except json.JSONDecodeError:
                continue
            msg = d.get("message")
            if not isinstance(msg, dict):
                continue
            content = msg.get("content")
            if not isinstance(content, list):
                continue
            started = _parse_iso_ts(d.get("timestamp"))
            for block in content:
                if not isinstance(block, dict):
                    continue
                btype = block.get("type")
                if btype == "tool_use" and block.get("name") in ("Agent", "Task"):
                    bid = block.get("id")
                    binput = block.get("input") or {}
                    if bid:
                        uses[bid] = {
                            "id": bid,
                            "description": binput.get("description", "") or "",
                            "subagent_type": binput.get("subagent_type", "") or "",
                            "started_at": started,
                        }
                elif btype == "tool_result":
                    tuid = block.get("tool_use_id")
                    if tuid:
                        results.add(tuid)
    except OSError:
        return []

    running = [u for uid, u in uses.items() if uid not in results]
    running.sort(key=lambda u: u.get("started_at") or 0)
    _RUNNING_AGENTS_CACHE[key] = (mtime, running)
    return running


def format_duration(secs: int) -> str:
    """Compact duration: 42s, 3m12s, 1h05m."""
    if secs < 60:
        return f"{secs}s"
    if secs < 3600:
        return f"{secs // 60}m{secs % 60:02d}s"
    return f"{secs // 3600}h{(secs % 3600) // 60:02d}m"


def format_tokens(n: int | None) -> str:
    """Human-readable token count: 0 -> '-', 12345 -> '12K', 1250000 -> '1.2M'."""
    if n is None or n <= 0:
        return "-"
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 10_000:
        return f"{n // 1000}K"
    if n >= 1_000:
        return f"{n / 1000:.1f}K"
    return str(n)


def short_model(model: str | None) -> str:
    """claude-opus-4-6 -> opus-4.6, claude-sonnet-4-5-20251022 -> sonnet-4.5."""
    if not model:
        return ""
    m = model.replace("claude-", "")
    m = re.sub(r"-\d{8}$", "", m)
    m = re.sub(r"^([a-z]+)-(\d+)-(\d+)$", r"\1-\2.\3", m)
    return m


def get_ollama_running() -> list[dict]:
    """Get currently loaded Ollama models via 'ollama ps'."""
    try:
        result = subprocess.run(
            ["ollama", "ps"], capture_output=True, text=True, timeout=5
        )
        if result.returncode != 0:
            return []
    except Exception:
        return []

    models = []
    for line in result.stdout.strip().split("\n")[1:]:  # skip header
        parts = line.split()
        if len(parts) >= 1:
            models.append({"name": parts[0], "raw": line.strip()})
    return models


def shorten_path(path: str, max_len: int = 35) -> str:
    home = str(Path.home())
    if path.startswith(home):
        path = "~" + path[len(home):]
    if len(path) <= max_len:
        return path
    return "..." + path[-(max_len - 3):]


def format_rss(mb: float) -> str:
    if mb >= 1024:
        return f"{mb / 1024:.1f}G"
    elif mb >= 1:
        return f"{mb:.0f}M"
    else:
        return f"{mb * 1024:.0f}K"


def task_summary(tasks: list[dict]) -> str:
    """One-line task summary: 'done/total taskname'."""
    if not tasks:
        return ""
    total = len(tasks)
    done = sum(1 for t in tasks if t.get("status") == "completed")
    active = [t for t in tasks if t.get("status") == "in_progress"]
    label = ""
    if active:
        t = active[0]
        label = t.get("activeForm") or t.get("subject", "")
        if len(label) > 30:
            label = label[:27] + "..."
    return f"{done}/{total} {label}"


def progress_mini(tasks: list[dict], width: int = 12) -> str:
    """Tiny progress bar."""
    if not tasks:
        return ""
    total = len(tasks)
    done = sum(1 for t in tasks if t.get("status") == "completed")
    active = sum(1 for t in tasks if t.get("status") == "in_progress")
    filled = round(done / total * width)
    partial = round(active / total * width)
    empty = width - filled - partial
    return "#" * filled + ":" * partial + "-" * empty


def draw(stdscr, interval: int):
    curses.curs_set(0)
    stdscr.nodelay(True)
    curses.use_default_colors()

    if curses.has_colors():
        curses.init_pair(1, curses.COLOR_GREEN, -1)
        curses.init_pair(2, curses.COLOR_RED, -1)
        curses.init_pair(3, curses.COLOR_CYAN, -1)
        curses.init_pair(4, curses.COLOR_YELLOW, -1)
        curses.init_pair(5, curses.COLOR_MAGENTA, -1)
        curses.init_pair(6, curses.COLOR_WHITE, -1)

    COL_GREEN = curses.color_pair(1) if curses.has_colors() else curses.A_NORMAL
    COL_RED = curses.color_pair(2) if curses.has_colors() else curses.A_NORMAL
    COL_CYAN = curses.color_pair(3) if curses.has_colors() else curses.A_NORMAL
    COL_YELLOW = curses.color_pair(4) if curses.has_colors() else curses.A_NORMAL
    COL_MAGENTA = curses.color_pair(5) if curses.has_colors() else curses.A_NORMAL
    COL_WHITE = curses.color_pair(6) if curses.has_colors() else curses.A_NORMAL
    COL_DIM = curses.A_DIM
    COL_BOLD = curses.A_BOLD

    LABEL_COLORS = {
        "Claude Code":       COL_GREEN | COL_BOLD,
        "Ollama Server":     COL_CYAN,
        "Ollama Model":      COL_CYAN | COL_BOLD,
        "Ollama Inference":  COL_CYAN,
        "llama.cpp Server":  COL_YELLOW,
        "llama.cpp CLI":     COL_YELLOW,
        "llama.cpp":         COL_YELLOW,
        "MLX LM":            COL_MAGENTA,
        "Aider":             COL_GREEN,
        "Copilot":           COL_GREEN,
        "Continue":          COL_GREEN,
    }

    sort_mode = "cpu"
    paused = False
    procs: list[dict] = []
    claude_sessions: dict[int, dict] = {}
    ollama_models: list[dict] = []
    gpu: int | None = None
    # LED state: previous token count per PID, and last-seen-active tick counter
    # so a change keeps the LED lit for a couple of refresh ticks.
    prev_tokens: dict[int, int] = {}
    led_ticks: dict[int, int] = {}
    LED_HOLD = 2

    while True:
        stdscr.erase()
        max_y, max_x = stdscr.getmaxyx()
        row = 0

        if not paused:
            procs = get_llm_processes()
            claude_sessions = load_claude_sessions()
            ollama_models = get_ollama_running()
            gpu = get_gpu_utilization()
            # Attach tokens to each proc so the sort key and LED can see them.
            for p in procs:
                p["tokens"] = None
                if p["label"] == "Claude Code" and p["pid"] in claude_sessions:
                    sess = claude_sessions[p["pid"]]
                    _, _, tok = get_session_info(sess.get("cwd", ""), sess.get("sessionId", ""))
                    p["tokens"] = tok

        procs.sort(key=SORT_MODES[sort_mode][1])
        now_str = datetime.now().strftime("%H:%M:%S")

        # Age the LED hold counter and drop dead PIDs.
        if not paused:
            alive_pids = {p["pid"] for p in procs}
            for pid in list(led_ticks.keys()):
                if pid not in alive_pids:
                    led_ticks.pop(pid, None)
                    prev_tokens.pop(pid, None)
                elif led_ticks[pid] > 0:
                    led_ticks[pid] -= 1

        # -- Title bar --
        total_cpu = sum(p["cpu"] for p in procs)
        total_mem = sum(p["rss_mb"] for p in procs)
        gpu_part = f"  |  GPU: {gpu}%" if gpu is not None else ""
        pause_part = "  |  PAUSED" if paused else ""
        title = f" ltop  |  {len(procs)} processes  |  CPU: {total_cpu:.1f}%{gpu_part}  |  MEM: {format_rss(total_mem)}  |  {now_str}{pause_part} "
        try:
            stdscr.addstr(row, 0, title.ljust(max_x - 1), curses.A_REVERSE | COL_BOLD)
        except curses.error:
            pass
        row += 1

        # -- Ollama loaded models (if any) --
        if ollama_models:
            try:
                stdscr.addstr(row, 0, f" Ollama models loaded: {', '.join(m['name'] for m in ollama_models)}", COL_CYAN)
            except curses.error:
                pass
            row += 1

        row += 1  # blank line

        # -- Column headers --
        hdr = f"{'PID':>7}  {'CPU%':>5}  {'MEM%':>5}  {'RSS':>6}  {'ELAPSED':>10}  {'TOKENS':>7}   {'TYPE':<20}  {'DETAILS'}"
        try:
            stdscr.addstr(row, 0, hdr[:max_x - 1], COL_BOLD | curses.A_UNDERLINE)
        except curses.error:
            pass
        row += 1

        if not procs:
            row += 1
            try:
                stdscr.addstr(row, 0, "  No LLM processes found.", COL_DIM)
            except curses.error:
                pass
            row += 2
        else:
            # -- Process rows --
            for p in procs:
                if row >= max_y - 4:
                    break

                pid = p["pid"]
                label = p["label"]
                details = ""
                is_idle = False
                tokens: int | None = None

                # Enrich Claude Code rows with session info
                if label == "Claude Code" and pid in claude_sessions:
                    sess = claude_sessions[pid]
                    cwd_full = sess.get("cwd", "")
                    cwd = shorten_path(cwd_full)
                    model_id, last_active, tokens = get_session_info(cwd_full, sess.get("sessionId", ""))
                    model = short_model(model_id)
                    model_tag = f" [{model}]" if model else ""
                    if last_active is not None:
                        is_idle = (time.time() - last_active) > ACTIVE_WINDOW_SECONDS
                    tasks = sess.get("tasks", [])
                    subagents = sess.get("subagents", [])
                    n_agents = 1 + len(subagents)
                    agent_tag = f"  ({n_agents} agents)" if n_agents > 1 else ""
                    if tasks:
                        tsumm = task_summary(tasks)
                        pbar = progress_mini(tasks)
                        details = f"{cwd}{model_tag}  [{pbar}] {tsumm}{agent_tag}"
                    else:
                        details = f"{cwd}{model_tag}{agent_tag}"
                elif label == "opencode":
                    cwd_full = get_process_cwd(pid)
                    model_id, last_active, tokens = get_opencode_info(cwd_full)
                    cwd = shorten_path(cwd_full) if cwd_full else ""
                    model = short_model(model_id)
                    model_tag = f" [{model}]" if model else ""
                    if last_active is not None:
                        is_idle = (time.time() - last_active) > ACTIVE_WINDOW_SECONDS
                    details = f"{cwd}{model_tag}".strip() or p["command"][:50]
                else:
                    # Show shortened command
                    cmd = p["command"]
                    if len(cmd) > 50:
                        cmd = cmd[:47] + "..."
                    details = cmd

                # Activity LED: block char. Blinking green = tokens flowing
                # (count changed within the last LED_HOLD ticks). Steady white
                # = idle. Rows without token enrichment get a blank slot.
                led_char = " "
                led_attr = curses.A_NORMAL
                if label in ("Claude Code", "opencode"):
                    if not paused and tokens is not None:
                        prev = prev_tokens.get(pid)
                        if prev is not None and tokens != prev:
                            led_ticks[pid] = LED_HOLD
                        prev_tokens[pid] = tokens
                    if led_ticks.get(pid, 0) > 0:
                        led_char = "\u2588"  # full block
                        led_attr = COL_GREEN | COL_BOLD | curses.A_BLINK
                    else:
                        led_char = "\u2588"
                        led_attr = COL_WHITE

                prefix = (
                    f"{pid:>7}  "
                    f"{p['cpu']:>5.1f}  "
                    f"{p['mem']:>5.1f}  "
                    f"{format_rss(p['rss_mb']):>6}  "
                    f"{p['elapsed']:>10}  "
                    f"{format_tokens(tokens):>7} "
                )
                suffix = f" {label:<20}  {details}"

                attr = LABEL_COLORS.get(label, curses.A_NORMAL)
                if is_idle:
                    attr = COL_DIM
                # Highlight high CPU
                if p["cpu"] > 50:
                    attr = COL_RED | COL_BOLD

                try:
                    stdscr.addstr(row, 0, prefix[:max_x - 1], attr)
                    x = min(len(prefix), max_x - 1)
                    if x < max_x - 1:
                        stdscr.addstr(row, x, led_char, led_attr)
                        x += 1
                    if x < max_x - 1:
                        stdscr.addstr(row, x, suffix[:max_x - 1 - x], attr)
                except curses.error:
                    pass
                row += 1

                # For Claude Code, show tasks and subagents below
                if label == "Claude Code" and pid in claude_sessions:
                    sess_data = claude_sessions[pid]
                    tasks = sess_data.get("tasks", [])
                    subagents = sess_data.get("subagents", [])
                    running_subs = get_running_subagents(
                        sess_data.get("cwd", ""),
                        sess_data.get("sessionId", ""),
                    )

                    # Render main agent tasks
                    for t in tasks:
                        if row >= max_y - 4:
                            break
                        status = t.get("status", "pending")
                        if status == "completed":
                            sym, tattr = "[done]", COL_GREEN | COL_DIM
                        elif status == "in_progress":
                            sym, tattr = "[ >> ]", COL_CYAN
                        else:
                            sym, tattr = "[    ]", COL_DIM

                        subj = t.get("subject", "")
                        if status == "in_progress":
                            subj = t.get("activeForm") or subj
                        if len(subj) > 70:
                            subj = subj[:67] + "..."

                        task_line = f"{'':>10}+- TASK {sym} {subj}"
                        try:
                            stdscr.addstr(row, 0, task_line[:max_x - 1], tattr)
                        except curses.error:
                            pass
                        row += 1

                    # Render currently-running subagents parsed from the
                    # transcript (tool_use without matching tool_result).
                    now = time.time()
                    for sub in running_subs:
                        if row >= max_y - 4:
                            break
                        sa_type = sub.get("subagent_type") or "agent"
                        desc = sub.get("description") or ""
                        if len(desc) > 50:
                            desc = desc[:47] + "..."
                        started = sub.get("started_at")
                        dur = format_duration(int(now - started)) if started else "?"
                        sub_line = f"{'':>10}+- SUB  [{sa_type}] {desc}  ({dur})"
                        try:
                            stdscr.addstr(row, 0, sub_line[:max_x - 1], COL_MAGENTA | COL_BOLD)
                        except curses.error:
                            pass
                        row += 1

                    # Render subagents
                    for sa in subagents:
                        if row >= max_y - 4:
                            break
                        todos = sa["todos"]
                        aid_short = sa["agent_id"][:8]
                        pbar = agent_progress_mini(todos)
                        summ = agent_todo_summary(todos)

                        sa_line = f"{'':>10}+-agent {aid_short}  [{pbar}] {summ}"
                        try:
                            stdscr.addstr(row, 0, sa_line[:max_x - 1], COL_MAGENTA)
                        except curses.error:
                            pass
                        row += 1

                        # Show individual subagent todos
                        for t in todos:
                            if row >= max_y - 4:
                                break
                            status = t.get("status", "pending")
                            if status == "completed":
                                sym, tattr = "[done]", COL_GREEN | COL_DIM
                            elif status == "in_progress":
                                sym, tattr = "[ >> ]", COL_MAGENTA
                            else:
                                sym, tattr = "[    ]", COL_DIM

                            content = t.get("content", "")
                            if status == "in_progress":
                                content = t.get("activeForm") or content
                            if len(content) > 50:
                                content = content[:47] + "..."

                            todo_line = f"{'':>54}  {sym} {content}"
                            try:
                                stdscr.addstr(row, 0, todo_line[:max_x - 1], tattr)
                            except curses.error:
                                pass
                            row += 1

        # -- Legend + footer (two lines) --
        legend_row = max_y - 2
        footer_row = max_y - 1
        sort_label = SORT_MODES[sort_mode][0]

        # Inline legend with actual LED colors so the symbol matches the rows.
        try:
            stdscr.move(legend_row, 0)
            stdscr.addstr(" LED: ", COL_BOLD)
            stdscr.addstr("\u2588", COL_GREEN | COL_BOLD | curses.A_BLINK)
            stdscr.addstr(" tokens flowing   ", curses.A_NORMAL)
            stdscr.addstr("\u2588", COL_WHITE)
            stdscr.addstr(" idle", curses.A_NORMAL)
            stdscr.clrtoeol()
        except curses.error:
            pass

        footer = (
            f" q:quit  p:cpu m:mem t:time k:tok  space:{'resume' if paused else 'pause'}"
            f"  sort:{sort_label}  interval:{interval}s "
        )
        try:
            stdscr.addstr(footer_row, 0, footer.ljust(max_x - 1), curses.A_REVERSE)
        except curses.error:
            pass

        stdscr.refresh()

        # Wait, checking for input every 100ms
        for _ in range(interval * 10):
            key = stdscr.getch()
            if key in (ord("q"), ord("Q"), 27):
                return
            elif key == ord("p"):
                sort_mode = "cpu"
                break
            elif key == ord("m"):
                sort_mode = "mem"
                break
            elif key == ord("t"):
                sort_mode = "time"
                break
            elif key == ord("k"):
                sort_mode = "tok"
                break
            elif key == ord(" "):
                paused = not paused
                break
            time.sleep(0.1)


def static_output():
    """One-shot plain text output for piping."""
    procs = get_llm_processes()
    procs.sort(key=SORT_MODES["cpu"][1])
    claude_sessions = load_claude_sessions()

    if not procs:
        print("No LLM processes found.")
        return

    print(f"{'PID':>7}  {'CPU%':>5}  {'MEM%':>5}  {'RSS':>6}  {'ELAPSED':>10}  {'TOKENS':>7}  {'TYPE':<20}  DETAILS")
    print("-" * 99)

    for p in procs:
        pid = p["pid"]
        label = p["label"]
        details = ""
        tokens: int | None = None

        if label == "Claude Code" and pid in claude_sessions:
            sess = claude_sessions[pid]
            cwd_full = sess.get("cwd", "")
            cwd = shorten_path(cwd_full)
            model_id, _, tokens = get_session_info(cwd_full, sess.get("sessionId", ""))
            model = short_model(model_id)
            model_tag = f" [{model}]" if model else ""
            tasks = sess.get("tasks", [])
            subagents = sess.get("subagents", [])
            n_agents = 1 + len(subagents)
            agent_tag = f"  ({n_agents} agents)" if n_agents > 1 else ""
            if tasks:
                details = f"{cwd}{model_tag}  {task_summary(tasks)}{agent_tag}"
            else:
                details = f"{cwd}{model_tag}{agent_tag}"
        else:
            cmd = p["command"]
            if len(cmd) > 50:
                cmd = cmd[:47] + "..."
            details = cmd

        print(
            f"{pid:>7}  "
            f"{p['cpu']:>5.1f}  "
            f"{p['mem']:>5.1f}  "
            f"{format_rss(p['rss_mb']):>6}  "
            f"{p['elapsed']:>10}  "
            f"{format_tokens(tokens):>7}  "
            f"{label:<20}  "
            f"{details}"
        )

        # Show subagents in static output too
        if label == "Claude Code" and pid in claude_sessions:
            for sa in claude_sessions[pid].get("subagents", []):
                todos = sa["todos"]
                aid_short = sa["agent_id"][:8]
                pbar = agent_progress_mini(todos)
                summ = agent_todo_summary(todos)
                print(f"{'':>10}+-agent {aid_short}  [{pbar}] {summ}")


def main():
    once = "--once" in sys.argv or "-1" in sys.argv

    interval = DEFAULT_INTERVAL
    argv = sys.argv[1:]
    for i, arg in enumerate(argv):
        if arg.startswith("--interval="):
            try:
                interval = max(1, int(arg.split("=", 1)[1]))
            except ValueError:
                pass
        elif arg.startswith("-n") and len(arg) > 2:
            try:
                interval = max(1, int(arg[2:]))
            except ValueError:
                pass
        elif arg == "-n" and i + 1 < len(argv):
            try:
                interval = max(1, int(argv[i + 1]))
            except ValueError:
                pass

    if "--help" in sys.argv or "-h" in sys.argv:
        print("ltop: A 'top'-like display for local LLM processes")
        print()
        print("Usage: ltop [OPTIONS]")
        print()
        print("Options:")
        print("  -n, --interval=N   Refresh interval in seconds (default: 3)")
        print("  -1, --once         Print once and exit (no TUI)")
        print("  -h, --help         Show this help")
        print()
        print("Interactive keys:")
        print("  q / Esc   Quit")
        print("  p         Sort by CPU")
        print("  m         Sort by memory")
        print("  t         Sort by elapsed time")
        print("  k         Sort by token count")
        print("  space     Pause / resume refresh")
        return

    # Windows requires psutil (no ps) and windows-curses. Fail early with
    # clear guidance rather than a confusing traceback.
    if sys.platform.startswith("win") and not HAVE_PSUTIL:
        print("ltop on Windows requires psutil: pip install psutil windows-curses",
              file=sys.stderr)
        sys.exit(1)

    if once or not sys.stdout.isatty():
        static_output()
    else:
        locale.setlocale(locale.LC_ALL, "")
        try:
            curses.wrapper(lambda stdscr: draw(stdscr, interval))
        except KeyboardInterrupt:
            pass


if __name__ == "__main__":
    main()
