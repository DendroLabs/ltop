# Patterns to identify LLM-related processes (command substring -> label)
LLM_PATTERNS = [
    (r"(^|/)claude(\s|$)",             "Claude Code"),
    (r"(^|/)opencode(\s|$)",           "opencode"),
    (r"ollama\s+serve",                "Ollama Server"),
    (r"ollama\s+run",                  "Ollama Model"),
    (r"ollama_llama_server",           "Ollama Inference"),
    (r"\bllama[-_]server\b",           "llama.cpp Server"),
    (r"\bllama[-_]cli\b",              "llama.cpp CLI"),
    (r"\bmain\b.*gguf",                "llama.cpp"),
    (r"LM\s*Studio|lmstudio",          "LM Studio"),
    (r"\bvllm\b",                      "vLLM"),
    (r"(^|[/\s])mlx[_-](lm|server)",   "MLX LM"),
    (r"text-generation-server",        "TGI"),
    (r"koboldcpp",                     "KoboldCpp"),
    (r"localai",                       "LocalAI"),
    (r"tabbyAPI|tabby",                "TabbyAPI"),
    (r"\bwhisper\b",                   "Whisper"),
    (r"stable.diffusion|comfy",        "Diffusion"),
    (r"(^|/)aider(\s|$)",              "Aider"),
    (r"github-copilot|gh\s+copilot",   "Copilot"),
    (r"continue\.dev|continue-server", "Continue"),
]

